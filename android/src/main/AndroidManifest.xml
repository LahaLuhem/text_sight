<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <!-- The unbundled OCR model loads lazily and app-controlled (TextSightModel.ensureReady()), so
         the `com.google.mlkit.vision.DEPENDENCIES` install-time prefetch meta-data is deliberately
         omitted — it would force a download for every consumer at install. A consumer that wants
         eager install-time prefetch can declare that meta-data in their own app manifest. -->
</manifest>
